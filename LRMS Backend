sure the bucket exists\nif not minio_client.bucket_exists(bucket_name):\n    minio_client.make_bucket(bucket_name)\n\n# Function to upload a file to MinIO\ndef upload_to_minio(file_path, bucket_name, object_name):\n    minio_client.fput_object(bucket_name, object_name, file_path)\n    object_url = f\"http://16.170.253.49:9000/{bucket_name}/{object_name}\"\n    return object_url","metadata":{"trusted":true},"execution_count":null,"outputs":[]},{"cell_type":"code","source":"# Function to generate captions using BLIP\ndef generate_caption(image_path):\n    image = Image.open(image_path)\n    inputs = blip_processor(images=image, return_tensors=\"pt\")\n    outputs = blip_model.generate(**inputs)\n    caption = blip_processor.decode(outputs[0], skip_special_tokens=True)\n    return caption\n\n# Function to get image embedding using CLIP\ndef get_image_embedding(image_path):\n    image = Image.open(image_path)\n    inputs = clip_processor(images=image, return_tensors=\"pt\")\n    outputs = clip_model.get_image_features(**inputs)\n    return outputs\n\n# Function to get text embedding using CLIP\ndef get_text_embedding(text):\n    inputs = clip_processor(text=[text], return_tensors=\"pt\")\n    outputs = clip_model.get_text_features(**inputs)\n    return outputs\n\n# Function to detect objects using YOLOv5\ndef detect_objects_in_image(image):\n    results = yolo_model(image)\n    objects = results.pandas().xyxy[0].to_dict(orient=\"records\")\n    object_names = [obj['name'] for obj in objects]\n    confidences = [obj['confidence'] for obj in objects]\n    return object_names, confidences\n\n# Function to extract high-resolution keyframes and their times\ndef extract_high_res_keyframes(video_path, shot_boundaries, fps):\n    cap = cv2.VideoCapture(video_path)\n    if not cap.isOpened():\n        print(\"Error opening video file\")\n        return []\n\n    keyframes = []\n    for boundary in shot_boundaries:\n        start_frame, end_frame = boundary\n        frame_to_capture = start_frame  # Adjust as needed based on your requirement\n\n        # Set the video capture to the selected frame\n        cap.set(cv2.CAP_PROP_POS_FRAMES, frame_to_capture)\n        ret, frame = cap.read()\n        if ret:\n            # Calculate start and end times\n            start_time = start_frame / fps\n            end_time = end_frame / fps\n\n            keyframes.append({\n                'frame': frame,\n                'start_time': start_time,\n                'end_time': end_time\n            })\n        else:\n            print(f\"Error reading frame at index {frame_to_capture}\")\n\n    cap.release()\n    return keyframes","metadata":{"trusted":true},"execution_count":null,"outputs":[]},{"cell_type":"code","source":"# Function to process images in folder and store metadata\ndef process_images_in_folder(folder_path, video_id, keyframes):\n    keyframe_metadata_list = []\n    objects_metadata_list = []\n    embeddings_metadata_list = []    \n    num_objects = 0  # Initialize object count\n\n    for idx, keyframe_data in enumerate(keyframes):\n        frame = keyframe_data['frame']\n        start_time = keyframe_data['start_time']\n        end_time = keyframe_data['end_time']\n\n        # Generate a keyframe file name using video_id and idx\n        keyframe_file = f\"keyframe_{video_id}_{idx}.jpg\"\n        keyframe_image_path = os.path.join(folder_path, keyframe_file)\n        cv2.imwrite(keyframe_image_path, frame)\n\n        # Upload keyframe image to MinIO\n        minio_url = upload_to_minio(keyframe_image_path, bucket_name, keyframe_file)\n\n        # Generate caption for the keyframe\n        caption = generate_caption(keyframe_image_path)\n\n        # Get image embedding using CLIP\n        image_embedding = get_image_embedding(keyframe_image_path)\n\n        # Get text embedding for the generated caption using CLIP\n        text_embedding = get_text_embedding(caption)\n\n        # Detect objects in the keyframe using YOLOv5\n        object_names, confidence_scores = detect_objects_in_image(frame)\n\n        # Prepare metadata for keyframe\n        keyframe_metadata = {\n            'video_id': video_id,\n            'image_id': f\"{video_id}_{idx}\",\n            'keyframe_file': keyframe_file,\n            'start_time': start_time,\n            'end_time': end_time,\n            'caption': caption,\n            'image_url': minio_url  # MinIO URL\n        }\n\n        # Check for duplicates before inserting keyframe metadata\n        existing_keyframe = keyframe_collection.find_one({\n            'video_id': video_id,\n            'image_id': f\"{video_id}_{idx}\"\n        })\n        if not existing_keyframe:\n            keyframe_metadata_list.append(keyframe_metadata)\n\n        # Prepare metadata for objects in the keyframe\n        for obj_name, confidence in zip(object_names, confidence_scores):\n            object_id = str(uuid.uuid4())\n            objects_metadata = {\n                'object_id': object_id,  # Add unique identifier for object\n                'video_id': video_id,\n                'image_id': f\"{video_id}_{idx}\",\n                'object_name': obj_name,\n                'confidence_score': confidence\n            }\n            existing_object = objects_collection.find_one({\n                'object_id': object_id,  # Add unique identifier for object\n                'video_id': video_id,\n                'image_id': f\"{video_id}_{idx}\"\n            })\n            if not existing_object:\n                objects_metadata_list.append(objects_metadata)\n                num_objects += 1  # Increment object count\n\n        # Prepare metadata for embeddings\n        embeddings_metadata = {\n            'video_id': video_id,\n            'image_id': f\"{video_id}_{idx}\",\n            'image_embedding': image_embedding.detach().cpu().numpy().tolist(),\n            'text_embedding': text_embedding.detach().cpu().numpy().tolist()\n        }\n        # Check for duplicates before inserting embeddings metadata\n        existing_embedding = embeddings_collection.find_one({\n            'video_id': video_id,\n            'image_id': f\"{video_id}_{idx}\"\n        })\n        if not existing_embedding:\n            embeddings_metadata_list.append(embeddings_metadata)\n        \n    if keyframe_metadata_list:\n        keyframe_collection.insert_many(keyframe_metadata_list)\n\n    if objects_metadata_list:\n        try:\n            objects_collection.insert_many(objects_metadata_list)\n        except BulkWriteError as bwe:\n            for error in bwe.details['writeErrors']:\n                print(f\"Error inserting object document: {error['errmsg']}\")\n            # Additional handling logic here (retry, skip problematic documents, etc.)\n\n    if embeddings_metadata_list:\n        embeddings_collection.insert_many(embeddings_metadata_list)\n\n    print(f\"Metadata saved successfully.\")\n    \n    return num_objects  # Return the number of objects\n","metadata":{"trusted":true},"execution_count":null,"outputs":[]},{"cell_type":"code","source":"# Function to process videos in a dataset\ndef process_videos_in_dataset(dataset_path):\n    # List to hold audit information\n    audit_data = []\n    video_files = [f for f in os.listdir(dataset_path) if f.endswith('.mp4')]\n    for video_file in video_files:\n        video_path = os.path.join(dataset_path, video_file)\n        video_id = os.path.basename(video_path).split('.')[0]\n\n        # Transcode the video\n        transcoded_video_path = os.path.join('/kaggle/working', f\"{video_id}_small.mp4\")\n        ffmpeg.input(video_path).output(transcoded_video_path, vcodec='libx264', crf=28, preset='fast').run()\n\n        # Upload the transcoded video to MinIO\n        video_object_name = f\"{video_id}_small.mp4\"\n        video_url = upload_to_minio(transcoded_video_path, bucket_name, video_object_name)\n\n        # Extract video properties\n        cap = cv2.VideoCapture(video_path)\n        fps = cap.get(cv2.CAP_PROP_FPS)\n        cap.release()\n\n        # Prepare video metadata\n        video_metadata = {\n            'video_id': video_id,\n            'fps': fps,\n            'video_url': video_url\n        }\n\n        # Insert video metadata into MongoDB if not already present\n        if not videos_collection.find_one({'video_id': video_id}):\n            videos_collection.insert_one(video_metadata)        \n\n        # Prepare the output directory for keyframes\n        output_dir = f'/kaggle/working/output/high_res_keyframes_{video_id}'\n        if not os.path.exists(output_dir):\n            os.makedirs(output_dir)\n\n        # Process the video and get frame-level predictions\n        video_frames, single_frame_predictions, all_frame_predictions = transnet.predict_video(video_path)\n\n        # Identify shot boundaries\n        shot_boundaries_transnet = transnet.predictions_to_scenes(single_frame_predictions)\n\n        # Extract high-resolution keyframes from the original video\n        high_res_keyframes = extract_high_res_keyframes(video_path, shot_boundaries_transnet, fps)\n\n        # Count the number of keyframes extracted\n        num_keyframes = len(high_res_keyframes)\n        print(f\"Number of high-resolution keyframes extracted from {os.path.basename(video_path)}: {num_keyframes}\")\n\n        # Save high-resolution keyframes\n        for idx, keyframe_data in enumerate(high_res_keyframes):\n            keyframe_image_path = os.path.join(output_dir, f\"keyframe_{idx}.jpg\")\n            keyframe = keyframe_data['frame']\n            cv2.imwrite(keyframe_image_path, keyframe)\n\n        print(f\"High-resolution keyframes saved for {os.path.basename(video_path)}\")\n\n        # Process and save images metadata to MongoDB and Excel\n        start_time = time.time()\n        num_objects = process_images_in_folder(output_dir, video_id, high_res_keyframes)\n        end_time = time.time()\n        print(f\"Metadata saved to MongoDB for {os.path.basename(video_path)} in {end_time - start_time} seconds\")\n        # Collect audit information\n        audit_data.append({\n            'video_id': video_id,\n            'num_keyframes': num_keyframes,\n            'num_objects': num_objects\n        })\n\n        # Clean up the temporary directory\n        shutil.rmtree(output_dir)\n\n    # Save audit information to an Excel file\n    audit_df = pd.DataFrame(audit_data)\n    audit_file_path = os.path.join('/kaggle/working', 'video_audit.xlsx')\n    audit_df.to_excel(audit_file_path, index=False)\n    print(f\"Audit information saved to {audit_file_path}\")","metadata":{"trusted":true},"execution_count":null,"outputs":[]},{"cell_type":"code","source":"# Example usage\ndataset_path = '/kaggle/input/video-dataset-R/Video Dataset R'  #Change Accordingly to your Dataset\nprocess_videos_in_dataset(dataset_path)","metadata":{"trusted":true},"execution_count":null,"outputs":[]}]}